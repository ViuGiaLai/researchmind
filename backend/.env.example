HOST=127.0.0.1
PORT=8765

# ─── Embedding & Search ─────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
ENABLE_RERANKER=false

# ─── LLM - Ollama (Local) ──────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
MODEL_TIER_WEAK=qwen2.5:3b
MODEL_TIER_MEDIUM=qwen2.5:7b
MODEL_TIER_STRONG=qwen2.5:14b

# ─── LLM - Claude ──────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── LLM - DeepSeek ────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ─── LLM - Gemini ──────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── LLM - NVIDIA NIM ──────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_MODEL=
NVIDIA_URL=
NVIDIA_DEEPSEEK_API_KEY=
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro

# ─── Mode: cloud_free / cloud_custom / local ───────────────
LLM_MODE=cloud_free
CUSTOM_CLOUD_PROVIDER=deepseek

# ─── Free cloud daily limit ────────────────────────────────
FREE_CLOUD_DAILY_LIMIT=10

# ─── Academic Verification (OpenAlex + Crossref) ───────────
# OpenAlex is free, no key required. Email helps priority pool.
OPENALEX_EMAIL=your@email.com
# Crossref is free. Email helps polite pool (faster rate limits).
CROSSREF_EMAIL=your@email.com
