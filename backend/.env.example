# ═══════════════════════════════════════════════════════════════════
# ResearchMind Backend — Environment Configuration Template
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765

# ─── Authentication & Identity ──────────────────────────────────
# Set to true to enable Firebase token verification on API endpoints.
FIREBASE_AUTH_ENABLED=false
HOSTED_RESEARCH_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
PUBLIC_BACKEND_URL=
DESKTOP_GOOGLE_CALLBACK_URL=http://127.0.0.1:8765/api/auth/desktop/google/callback

# ─── ResearchMind Cloud Gateway ─────────────────────────────────
# Backend routes AI requests through this gateway instead of calling
# providers directly. Set RESEARCHMIND_CLOUD_URL or place a gateway.json
# file in the backend directory with {"url": "https://..."}.
# RESEARCHMIND_CLOUD_URL=https://your-gateway.onrender.com
# Must match GATEWAY_SHARED_TOKEN on the gateway server.
RESEARCHMIND_CLOUD_TOKEN=

# ─── LLM Mode ───────────────────────────────────────────────────
# cloud_free  — Use Cloud Gateway (free, rate-limited for guests)
# cloud_custom — Use your own API keys (BYOK)
# local        — Use local llama-server / Ollama
LLM_MODE=cloud_free
CUSTOM_CLOUD_PROVIDER=deepseek
FREE_CLOUD_DAILY_LIMIT=20
OUTPUT_LANGUAGE=auto

# ─── LLM - Local (llama-server / Ollama) ────────────────────────
LLAMA_SERVER_URL=http://127.0.0.1:8080
LOCAL_MODEL=Qwen3-4B-Q4_K_M.gguf

# ─── LLM - BYOK Provider Keys (only needed in cloud_custom mode) ─
# Uncomment and fill the providers you want to use with your own keys.
# When using Cloud Gateway (cloud_free), keys live on the gateway server.
#
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514
#
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
#
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
#
# GEMINI_TRANSLATE_API_KEY=
# GEMINI_TRANSLATE_MODEL=gemini-2.5-flash
#
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
#
# NVIDIA_API_KEY=
# NVIDIA_MODEL=moonshotai/kimi-k2.6
# NVIDIA_DEEPSEEK_API_KEY=
# NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro
#
# GITHUB_API_KEY=
# GITHUB_MODEL=gpt-4o-mini
# GITHUB_URL=https://models.inference.ai.azure.com
# GITHUB_DEEPSEEK_V3_API_KEY=
# GITHUB_DEEPSEEK_V3_MODEL=DeepSeek-V3-0324
#
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_DEEP_KEY=
# OPENROUTER_DEEP_MODEL=deepseek/deepseek-r1
#
# FREEMODEL_API_KEY=
# FREEMODEL_MODEL=gpt-4o-mini
# FREEMODEL_URL=https://api.freemodel.dev/v1
#
# COHERE_API_KEY=
# COHERE_MODEL=command-r-plus
# COHERE_URL=https://api.cohere.ai/v1
#
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
# CLOUDFLARE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1
#
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
# CEREBRAS_URL=https://api.cerebras.ai/v1

# ─── Embedding ──────────────────────────────────────────────────
# local mode: BAAI/bge-m3 (dim=1024) runs on CPU
# cloud mode: gemini-embedding-001 (dim=768) uses Gemini API
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_MODE=local
EMBEDDING_DIM=1024

# ─── Reranker ───────────────────────────────────────────────────
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ─── Chunking ───────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ─── Search ─────────────────────────────────────────────────────
TOP_K_RETRIEVAL=5
SIMILARITY_CUTOFF=0.1

# ─── GraphRAG ───────────────────────────────────────────────────
GRAPH_ENABLED=true
GRAPH_MAX_GLEANINGS=0
GRAPH_ENTITY_TYPES=CONCEPT,METHOD,DATASET,METRIC,MODEL,ALGORITHM,ARCHITECTURE,TASK,DOMAIN
GRAPH_MAX_CLUSTER_SIZE=10
GRAPH_TOP_K_ENTITIES=10
GRAPH_TOP_K_RELATIONSHIPS=10
GRAPH_MAX_DRIFT_STEPS=3

# ─── Academic Verification ──────────────────────────────────────
OPENALEX_EMAIL=
CROSSREF_EMAIL=

# ─── Data & Storage ─────────────────────────────────────────────
# Override the default data directory (~/.researchmind or %LOCALAPPDATA%\ResearchMind)
# DATA_DIR=
# ZOTERO_DATA_DIR=

# ─── User Preferences ──────────────────────────────────────────
CLOUD_AI_CONSENT=true
DIAGNOSTICS_CONSENT=false
SETUP_COMPLETED=false

# ─── Per-Task Provider Routing ──────────────────────────────────
# Maps each AI task to a preferred provider. If not set, uses cloud_free chain.
# Valid providers: github, gemini, deepseek, groq, nvidia, nvidia_deepseek,
#   freemodel, claude, local, openrouter, cohere, cloudflare, cerebras,
#   github_deepseek_v3
TASK_PROVIDER_MAP={"summary":"github","daily_reader":"github","chat":"github","quality_check":"github","insight":"github","rag":"gemini","gap":"deepseek","critique":"gemini","debate":"deepseek","verify":"gemini","review":"deepseek","graph":"cerebras","research":"deepseek","synthesis":"deepseek","entity":"github","review_outline":"groq","review_section":"deepseek"}

# Fallback when primary provider fails
TASK_FALLBACK_MAP={"summary":"cloudflare","daily_reader":"cohere","chat":"openrouter","quality_check":"cohere","insight":"openrouter","rag":"cerebras","gap":"gemini","critique":"deepseek","debate":"gemini","verify":"deepseek","review":"gemini","graph":"gemini","research":"gemini","synthesis":"gemini","entity":"cohere","review_outline":"gemini","review_section":"gemini"}

# Ultimate fallback chain when primary + fallback both fail
TASK_ULTIMATE_FALLBACK_CHAIN=cerebras,groq,nvidia,nvidia_deepseek,github,github_deepseek_v3,cohere,cloudflare,openrouter,local
