HOST=127.0.0.1
PORT=8765

# ─── Embedding & Search ─────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ─── LLM - llama-server (Local GGUF) ──────────────────────
LLAMA_SERVER_URL=http://127.0.0.1:8080
LOCAL_MODEL=Qwen3-4B-Q4_K_M.gguf

# ─── LLM - Claude ──────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── LLM - DeepSeek ────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ─── LLM - Gemini ──────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── LLM - Groq (OpenAI-compatible) ────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── LLM - NVIDIA (OpenAI-compatible) ─────────────────────
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2.6

# ─── LLM - NVIDIA DeepSeek ────────────────────────────────
NVIDIA_DEEPSEEK_API_KEY=
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro

# ─── LLM - FreeModel.dev (OpenAI-compatible proxy) ─────────
FREEMODEL_API_KEY=
FREEMODEL_MODEL=gpt-4o-mini

# ─── LLM - GitHub Models (Azure AI Foundry, free with GitHub PAT) ─
GITHUB_API_KEY=
GITHUB_MODEL=gpt-4o-mini
GITHUB_URL=https://models.inference.ai.azure.com

# ─── LLM - OpenRouter (OpenAI-compatible marketplace) ─────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_URL=https://openrouter.ai/api/v1

# ─── LLM - Cohere (OpenAI-compatible via Compatibility API) ──
COHERE_API_KEY=
COHERE_MODEL=command-r-plus
COHERE_URL=https://api.cohere.ai/v1

# ─── LLM - Cloudflare Workers AI (OpenAI-compatible) ──────
CLOUDFLARE_API_KEY=
CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CLOUDFLARE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1

# ─── LLM - Cerebras (OpenAI-compatible, ultra-fast) ──────
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
CEREBRAS_URL=https://api.cerebras.ai/v1

# ─── Mode: cloud_free / cloud_custom / local ───────────────
LLM_MODE=cloud_free
CUSTOM_CLOUD_PROVIDER=deepseek

# ─── Free cloud daily limit ────────────────────────────────
FREE_CLOUD_DAILY_LIMIT=10

# ─── Academic Verification (OpenAlex + Crossref) ───────────
OPENALEX_EMAIL=
CROSSREF_EMAIL=

# ═══════════════════════════════════════════════════════════════════
# PHASE 1+2+3: Per-Task Provider Routing (HOÀN THIỆN 100%)
# ═══════════════════════════════════════════════════════════════════
# Provider hợp lệ: github, gemini, deepseek, groq, nvidia, freemodel,
#                   claude, local, openrouter, cohere, cloudflare, cerebras
# Nếu không mapping → dùng chain cloud_free mặc định (GitHub→Gemini→Groq→...)
# ═══════════════════════════════════════════════════════════════════
#
# 📋 Bảng phân bổ ĐẦY ĐỦ
#
# Mức   Module                    Chính               Fallback
# ⭐    Summary / Highlights      github              cloudflare
# ⭐    Daily Reader              github              cohere
# ⭐⭐  Chat AI đơn giản          github              openrouter
# ⭐⭐  Quality Check             github              cohere
# ⭐⭐  Insights thường           github              openrouter
# ⭐⭐⭐ Chat AI + paper (RAG)    gemini              cerebras
# ⭐⭐⭐⭐ Research Gap            deepseek            gemini
# ⭐⭐⭐⭐ Critique                gemini              deepseek
# ⭐⭐⭐⭐ Debate                  deepseek            gemini
# ⭐⭐⭐⭐⭐ Verify                 gemini              deepseek (V4 Pro)
# ⭐⭐⭐⭐⭐ Review Builder         deepseek            gemini
# ⭐⭐⭐⭐⭐ GraphRAG extraction    cerebras            gemini
# ⭐⭐⭐⭐⭐ Deep Research          deepseek            gemini
# ⭐⭐⭐⭐⭐ Multi-paper synthesis  deepseek            gemini
# ⭐⭐⭐⭐  Entity extraction       github              cohere
# —       Embedding              BGE-M3 local        Cohere Embed
# —       Reranker               BGE-Reranker        —
#
# 👉 Chính = provider được mapping trong TASK_PROVIDER_MAP bên dưới
# 👉 Fallback = nếu provider chính lỗi, tự động rơi xuống chain cloud_free
#    (GitHub → Gemini → Groq → NVIDIA → local)
# 👉 Để dùng DeepSeek V4 Pro cho verify, cần set DEEPSEEK_MODEL=deepseek-v4-pro
#    Hoặc dùng OpenRouter với model deepseek/deepseek-v4-pro
#
# Cấu hình chính xác theo bảng trên:
TASK_PROVIDER_MAP={"summary":"github","daily_reader":"github","chat":"github","quality_check":"github","insight":"github","rag":"gemini","gap":"deepseek","critique":"gemini","debate":"deepseek","verify":"gemini","review":"deepseek","graph":"cerebras","research":"deepseek","synthesis":"deepseek","entity":"github"}



# ─── Per-Task Fallback Provider Mapping (Phase 4A) ────────────────
# Khi provider chính fail (no key, rate limit, error) → dùng fallback
# Nếu fallback cũng fail → fallback về default chain (cloud_free / cloud_custom / local)
TASK_FALLBACK_MAP={"summary":"cloudflare","daily_reader":"cohere","chat":"openrouter","quality_check":"cohere","insight":"openrouter","rag":"cerebras","gap":"gemini","critique":"deepseek","debate":"gemini","verify":"deepseek","review":"gemini","graph":"gemini","research":"gemini","synthesis":"gemini","entity":"cohere"}

# ─── Embedding 
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_MODE=local
EMBEDDING_DIM=1024

# ─── Chunking ─
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ─── Search ───
TOP_K_RETRIEVAL=5
SIMILARITY_CUTOFF=0.1
ENABLE_RERANKER=True

# ─── GraphRAG 
GRAPH_ENABLED=True
GRAPH_MAX_GLEANINGS=2
GRAPH_ENTITY_TYPES=CONCEPT,METHOD,DATASET,METRIC,MODEL,ALGORITHM,ARCHITECTURE,TASK,DOMAIN
GRAPH_MAX_CLUSTER_SIZE=10
GRAPH_TOP_K_ENTITIES=10
GRAPH_TOP_K_RELATIONSHIPS=10
GRAPH_MAX_DRIFT_STEPS=3

# ─── Academic ──
OPENALEX_EMAIL=
CROSSREF_EMAIL=
