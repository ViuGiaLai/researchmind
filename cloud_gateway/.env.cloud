# ─── ResearchMind Cloud Gateway — Environment Variables ───────────────
# Copy sang Render dashboard > Environment Variables (dạng Key-Value)
# Lấy giá trị từ backend/.env — KHÔNG commit file này lên git nếu còn key thật!
# Sau khi copy xong, xoá file này hoặc giữ template.

ENVIRONMENT=production
ALLOW_UNAUTHENTICATED=false

# ─── Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Groq ────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenRouter ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_R1_API_KEY=
OPENROUTER_R1_MODEL=deepseek/deepseek-r1

# ─── Cerebras ────────────────────────────────────────────────────────
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# ─── Cloudflare Workers AI ───────────────────────────────────────────
CLOUDFLARE_API_KEY=
CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CLOUDFLARE_URL=

# ─── Claude ──────────────────────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── DeepSeek ────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ─── GitHub Models ───────────────────────────────────────────────────
GITHUB_API_KEY=
GITHUB_MODEL=gpt-4o-mini
GITHUB_DEEPSEEK_V3_API_KEY=
GITHUB_DEEPSEEK_V3_MODEL=DeepSeek-V3-0324

# ─── NVIDIA ──────────────────────────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2.6
NVIDIA_DEEPSEEK_API_KEY=
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro

# ─── FreeModel ───────────────────────────────────────────────────────
FREEMODEL_API_KEY=
FREEMODEL_MODEL=gpt-4o-mini

# ─── Cohere ──────────────────────────────────────────────────────────
COHERE_API_KEY=
COHERE_MODEL=command-r-plus

# ─── Task routing ────────────────────────────────────────────────────
TASK_PROVIDER_MAP={"summary":"groq","daily_reader":"github","chat":"github","quality_check":"github","insight":"github","rag":"gemini","gap":"nvidia_deepseek","critique":"gemini","debate":"nvidia_deepseek","verify":"gemini","review":"nvidia_deepseek","graph":"cerebras","research":"groq","synthesis":"groq","entity":"cerebras"}
PROVIDER_FALLBACK_CHAIN=groq,cerebras,cloudflare,nvidia,nvidia_deepseek,github,github_deepseek_v3,cohere,openrouter,openrouter_r1,deepseek,freemodel,claude
