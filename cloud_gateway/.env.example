ENVIRONMENT=development
ALLOW_UNAUTHENTICATED=true
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
GATEWAY_SHARED_TOKEN=
FREE_REQUESTS_PER_DAY=30
FREE_INPUT_CHARS_PER_DAY=500000

# ─── Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Groq ────────────────────────────────────────────────────────────
GROQ_API_KEY=
