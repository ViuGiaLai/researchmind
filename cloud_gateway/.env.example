# ═══════════════════════════════════════════════════════════════════
# ResearchMind — Cloud Gateway Environment Template (.env.example)
# Copy this file to .env on your Render/server deployment.
# ═══════════════════════════════════════════════════════════════════

# ─── System & Security ──────────────────────────────────────────────
ENVIRONMENT=development
ALLOW_UNAUTHENTICATED=true
CORS_ORIGINS=http://localhost:1420,tauri://localhost

# Shared token that client apps / backend must pass in Authorization header
GATEWAY_SHARED_TOKEN=your-secret-token-here

# Firebase Admin SDK (optional)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Daily Quota Limits (Unauthenticated / Guest) ───────────────────
FREE_REQUESTS_PER_DAY=30
FREE_INPUT_CHARS_PER_DAY=500000

# ─── Request Bounds & Timeouts ─────────────────────────────────────
MAX_INPUT_CHARS=120000
MAX_OUTPUT_TOKENS=4096
PROVIDER_TIMEOUT=120.0

# ─── Provider API Keys & Models ────────────────────────────────────

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_R1_API_KEY=
OPENROUTER_R1_MODEL=deepseek/deepseek-r1

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# Cloudflare Workers AI
CLOUDFLARE_API_KEY=
CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CLOUDFLARE_URL=

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# GitHub Models
GITHUB_API_KEY=
GITHUB_MODEL=gpt-4o-mini
GITHUB_DEEPSEEK_V3_API_KEY=
GITHUB_DEEPSEEK_V3_MODEL=DeepSeek-V3-0324

# NVIDIA
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2.6
NVIDIA_DEEPSEEK_API_KEY=
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro

# FreeModel
FREEMODEL_API_KEY=
FREEMODEL_MODEL=gpt-4o-mini

# Cohere
COHERE_API_KEY=
COHERE_MODEL=command-r-plus

# ─── Routing & Policy Overrides ────────────────────────────────────
ROUTING_POLICY={"chat.fast":["gemini","github","groq"],"chat.deep":["deepseek","openrouter","nvidia_deepseek","gemini"],"chat.deep_plus":["openrouter_r1","deepseek","nvidia_deepseek","gemini"],"rag.fast":["gemini","groq","cerebras"],"rag.deep":["deepseek","gemini","nvidia"],"rag.deep_plus":["openrouter_r1","deepseek","gemini"],"review_outline":["groq","gemini","cerebras"],"review_section":["nvidia_deepseek","deepseek","gemini"],"review":["nvidia_deepseek","deepseek","gemini"],"verify":["gemini","deepseek","groq"],"critique":["gemini","deepseek","nvidia"],"debate":["nvidia_deepseek","deepseek","gemini"],"summary":["groq","gemini","cerebras"],"quality_check":["github","gemini","groq"],"translate":["gemini","groq"],"entity":["cerebras","groq"],"research":["deepseek","groq","gemini"],"synthesis":["deepseek","groq","gemini"],"daily_reader":["github","gemini","groq"],"gap":["deepseek","nvidia_deepseek","gemini"],"insight":["github","gemini","groq"]}

PROVIDER_FALLBACK_CHAIN=groq,cerebras,cloudflare,nvidia,nvidia_deepseek,github,github_deepseek_v3,cohere,openrouter,openrouter_r1,deepseek,freemodel,claude
