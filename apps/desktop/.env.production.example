# ResearchMind Desktop — Production Environment Template
# ═══════════════════════════════════════════════════════════════════

# Public URL of the hosted ResearchMind backend
VITE_BACKEND_URL=https://your-researchmind-api.onrender.com

# Firebase Auth (Production)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Clerk Authentication (Production Publishable Key)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Cloud Sync API (Production Worker)
VITE_CLOUD_SYNC_URL=https://sync.your-domain.com
