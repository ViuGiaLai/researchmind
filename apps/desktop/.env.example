# ═══════════════════════════════════════════════════════════════════
# ResearchMind Desktop — Frontend Environment Template
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# Backend API URL (local FastAPI server)
VITE_BACKEND_URL=http://127.0.0.1:8765

# Firebase Auth (legacy — used when Clerk is not configured)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Clerk Authentication (recommended — replaces Firebase)
# Get your key at https://dashboard.clerk.com → API Keys
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Cloud Sync API (Cloudflare Worker for settings sync & backup)
VITE_CLOUD_SYNC_URL=http://localhost:8787

# Public Website & Web Reports Domain (Cloudflare Pages)
VITE_PUBLIC_PAGES_URL=https://researchmind.pages.dev

