# Backend API URL (FastAPI server)
VITE_BACKEND_URL=http://127.0.0.1:8765
# Local backend is not required to verify Firebase tokens.
VITE_BACKEND_AUTH_REQUIRED=false
# Local-first build: users may use the app without signing in.
VITE_AUTH_REQUIRED=true

# =====================================================================
# Phase 2: Cloud Sync & Authentication
# =====================================================================

# VITE_CLOUD_SYNC_URL: Trỏ đến Cloudflare Worker API
VITE_CLOUD_SYNC_URL=http://localhost:8787

# Clerk Authentication (thay thế Firebase)
# Sign up: https://dashboard.clerk.com → Get API Keys → Publishable Key
# Khi có key này, app sẽ dùng Clerk thay vì mock provider.
# Bỏ comment dòng dưới và thay bằng key thật của bạn.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Bật/Tắt nút Quick Login (Dev) — đăng nhập tức thì không cần email/password
VITE_QUICK_LOGIN=false

# Bật/Tắt chế độ Cloud Sync
VITE_ENABLE_CLOUD_SYNC=true

# =====================================================================
# Firebase Auth (legacy — chỉ dùng nếu không có Clerk)
# =====================================================================
# VITE_FIREBASE_API_KEY=AIzaSy...
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123
