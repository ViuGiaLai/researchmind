# =====================================================================
# ResearchMind - Giai Đoạn 2: Cloud Sync & Authentication
# File cấu hình môi trường (.env) cho Cloudflare Workers (cloud-sync)
# LƯU Ý: Tuyệt đối không commit file .env chứa key thật lên Git!
# =====================================================================

# 1. Clerk Authentication (Identity Provider Mặc định)
# Lấy từ https://dashboard.clerk.com/
# Publishable key dùng cho Frontend
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Secret key dùng cho Backend/Workers để verify JWT
CLERK_SECRET_KEY=sk_test_...

# 2. Cloudflare API & D1 Database
# Lấy từ https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# D1 Database Bindings
# Chạy lệnh `wrangler d1 create researchmind_db` để lấy ID
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id_here

# 3. Môi trường hệ thống
NODE_ENV=development
# CORS Origins (Cho phép app chạy ở Local Tauri gọi API)
ALLOWED_ORIGINS=http://localhost:1420,tauri://localhost
