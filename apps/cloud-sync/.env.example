# ═══════════════════════════════════════════════════════════════════
# ResearchMind — Cloud Sync Worker Environment Template (.env.example)
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# 1. Clerk Authentication (Secret key for JWT verification)
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
# Optional: Clerk public JWT key for offline verification
CLERK_JWT_KEY=

# 2. Cloudflare API & D1 Database
# Get from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
# Run `wrangler d1 create researchmind_db` to get ID
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id_here

# 3. Environment & Security
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:1420,tauri://localhost
